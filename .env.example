PORT=3000
DB_PATH=./data/albion.db

# Chave mestra usada só pra gerar novas API keys de contribuidor (endpoint admin)
ADMIN_SECRET=troque-isso-aqui

# URL do dump oficial de items (ao-bin-dumps)
ITEMS_JSON_URL=https://raw.githubusercontent.com/ao-data/ao-bin-dumps/master/formatted/items.json

# Região do AODP público usada só pra LER baseline (west | europe | east)
PUBLIC_SYNC_REGION=europe

# Rate limit: máximo de fetches do AODP por IP por minuto
RATE_LIMIT_FETCH_PER_MINUTE=10

# Cache: TTL em ms do cache de preços latest
CACHE_LATEST_TTL_MS=60000
